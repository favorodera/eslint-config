{
  "name": "@favorodera/eslint-config",
  "type": "module",
  "version": "0.0.0",
  "description": "A starter for creating a TypeScript package.",
  "author": "Favour Emeka <favorodera@gmail.com>",
  "funding": "https://github.com/sponsors/favorodera",
  "license": "MIT",
  "private": false,
  "homepage": "https://github.com/favorodera/eslint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/favorodera/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/favorodera/eslint-config/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "scripts": {
    "script:generate-rules-types": "tsx scripts/generate-rules-types.ts",
    "prebuild": "pnpm script:generate-rules-types",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "lint": "eslint . --fix",
    "ready": "pnpm install && pnpm lint && pnpm typecheck && pnpm build && pnpm test"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "eslint": "^10.4.1",
    "relizy": "^1.4.6",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "eslint": "^10.0.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "keywords": [
    "nuxt",
    "vue",
    "eslint",
    "typescript",
    "stylistic",
    "tooling",
    "linter"
  ],
  "dependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "defu": "^6.1.7",
    "eslint-flat-config-utils": "^3.2.0",
    "eslint-merge-processors": "^2.0.0",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "eslint-processor-vue-blocks": "^2.0.0",
    "eslint-typegen": "^2.3.1",
    "typescript-eslint": "^8.60.1",
    "vue-eslint-parser": "^10.4.1"
  }
}
