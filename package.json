{
  "name": "@favorodera/eslint-config",
  "type": "module",
  "version": "1.0.4",
  "private": false,
  "packageManager": "pnpm@11.2.2",
  "description": "Opinionated, type-safe flat ESLint configuration factory for Vue, TypeScript, Tailwind, and more.",
  "author": "Favour Emeka <favorodera@gmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/favorodera",
  "homepage": "https://github.com/favorodera/eslint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/favorodera/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/favorodera/eslint-config/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nuxt",
    "vue",
    "eslint",
    "typescript",
    "stylistic",
    "tooling",
    "linter"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "script:generate-rules-types": "tsx scripts/generate-rules-types.ts",
    "dev:inspector": "pnpm dlx @eslint/config-inspector@latest",
    "prebuild": "pnpm script:generate-rules-types",
    "build": "tsdown",
    "dev": "pnpm prebuild && concurrently \"tsdown --watch\" \"pnpm dev:inspector\"",
    "test": "vitest run",
    "test:watch": "vitest --watch --ui",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "lint": "eslint . --fix",
    "ready": "pnpm install && pnpm build && pnpm lint && pnpm typecheck && pnpm test"
  },
  "peerDependencies": {
    "eslint": "catalog:peer"
  },
  "dependencies": {
    "@eslint/js": "catalog:prod",
    "@eslint/markdown": "catalog:prod",
    "@stylistic/eslint-plugin": "catalog:prod",
    "@vitest/eslint-plugin": "catalog:prod",
    "defu": "catalog:prod",
    "eslint-flat-config-utils": "catalog:prod",
    "eslint-merge-processors": "catalog:prod",
    "eslint-plugin-better-tailwindcss": "catalog:prod",
    "eslint-plugin-import-lite": "catalog:prod",
    "eslint-plugin-jsdoc": "catalog:prod",
    "eslint-plugin-jsonc": "catalog:prod",
    "eslint-plugin-n": "catalog:prod",
    "eslint-plugin-perfectionist": "catalog:prod",
    "eslint-plugin-pnpm": "catalog:prod",
    "eslint-plugin-unicorn": "catalog:prod",
    "eslint-plugin-unused-imports": "catalog:prod",
    "eslint-plugin-vue": "catalog:prod",
    "eslint-plugin-vuejs-accessibility": "catalog:prod",
    "eslint-plugin-yml": "catalog:prod",
    "eslint-processor-vue-blocks": "catalog:prod",
    "globals": "catalog:prod",
    "typescript-eslint": "catalog:prod",
    "vue-eslint-parser": "catalog:prod",
    "yaml-eslint-parser": "catalog:prod"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "@typescript/native-preview": "catalog:dev",
    "@vitest/ui": "catalog:dev",
    "concurrently": "catalog:dev",
    "eslint": "catalog:dev",
    "eslint-typegen": "catalog:dev",
    "relizy": "catalog:dev",
    "tsdown": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  }
}
