{
  "name": "@favorodera/eslint-config",
  "type": "module",
  "version": "0.0.5",
  "private": false,
  "packageManager": "pnpm@11.2.2",
  "description": "Opinionated, type-safe flat ESLint configuration factory for Vue, TypeScript, Tailwind, and more.",
  "author": "Favour Emeka <favorodera@gmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/favorodera",
  "homepage": "https://github.com/favorodera/eslint-config#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/favorodera/eslint-config.git"
  },
  "bugs": {
    "url": "https://github.com/favorodera/eslint-config/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "nuxt",
    "vue",
    "eslint",
    "typescript",
    "stylistic",
    "tooling",
    "linter"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "script:generate-rules-types": "tsx scripts/generate-rules-types.ts",
    "dev:inspector": "pnpm dlx @eslint/config-inspector@latest",
    "prebuild": "pnpm script:generate-rules-types",
    "build": "tsdown",
    "dev": "pnpm prebuild && concurrently \"tsdown --watch\" \"pnpm dev:inspector\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "lint": "eslint . --fix",
    "ready": "pnpm install && pnpm build && pnpm lint && pnpm typecheck && pnpm test"
  },
  "peerDependencies": {
    "eslint": "^10.0.0"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.2",
    "@stylistic/eslint-plugin": "^5.10.0",
    "defu": "^6.1.7",
    "eslint-flat-config-utils": "^3.2.0",
    "eslint-merge-processors": "^2.0.0",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-import-lite": "^0.6.0",
    "eslint-plugin-jsdoc": "^63.0.2",
    "eslint-plugin-jsonc": "^3.2.0",
    "eslint-plugin-n": "^18.1.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unicorn": "^65.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "eslint-plugin-yml": "^3.4.0",
    "eslint-processor-vue-blocks": "^2.0.0",
    "globals": "^17.6.0",
    "typescript-eslint": "^8.60.1",
    "vue-eslint-parser": "^10.4.1",
    "yaml-eslint-parser": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "eslint-typegen": "^2.3.1",
    "relizy": "^1.4.6",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
